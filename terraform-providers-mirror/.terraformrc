# Terraform CLI Configuration File for Fully Offline Environment
# Core Function: Only load local filesystem mirror, disable all public network requests, avoid offline environment errors
# Adapt to Docker Container: path must be set to /terraform-providers-mirror (consistent with the mirror directory in Dockerfile)
provider_installation {
  # Local filesystem mirror configuration (Key: Fixed path for Docker environment, no modification needed)
  # 1. Docker Offline Environment: Fixed to /terraform-providers-mirror (consistent with Dockerfile)
  # 2. Non-Docker Offline Environment: Path is the local mirror directory (e.g., /opt/terraform-mirror, D:\\terraform-mirror)
  filesystem_mirror {
    path    = "/terraform-providers-mirror"  # Fixed path in Docker container (Required)
    # path    = "/opt/terraform-mirror"      # Example: Linux/macOS non-Docker environment path
    # path    = "D:\\terraform-mirror"      # Example: Windows non-Docker environment path (note double backslashes)
    include = ["registry.terraform.io/*/*"]  # Match all official Providers (e.g., hashicorp)
    include = ["*/*"]  # Match all third-party Providers (e.g., custom, private repository Providers)
  }

  # Disable direct download from public network (Key configuration for full offline, cannot be deleted)
  direct {
    exclude = ["*/*"]  # Exclude public network download requests for all Providers
  }
}

# Optional Configuration: Disable Telemetry (avoid Terraform attempting to connect to public network for data reporting)
telemetry {
  disable = true
}

# Optional Configuration: Specify plugin cache directory (reuse downloaded plugins in offline environment to speed up init)
# plugin_cache_dir = "/opt/terraform-plugin-cache"  # Example: Linux/macOS
# plugin_cache_dir = "D:\\terraform-plugin-cache"  # Example: Windows
# plugin_cache_dir = "/terraform-plugin-cache"     # Example: Inside Docker container

# Supplement: Explanation of -plugin-dir (commonly used in fully offline scenarios)
# 1. Core Definition: -plugin-dir is a "temporary plugin directory parameter" for the terraform init command, not a .terraformrc configuration item
# Function: Force Terraform to load Provider plugins from the specified directory during initialization, no need to rely on mirror configuration, suitable for temporary offline scenarios
# 2. Offline Usage Examples (execute in command line, replace with your actual plugin directory):
# Linux/macOS (non-Docker): terraform init -plugin-dir=/opt/terraform-plugins
# Windows: terraform init -plugin-dir=D:\\terraform-plugins
# Inside Docker container: terraform init -plugin-dir=/terraform-providers-mirror/registry.terraform.io
# 3. Directory Requirements: The plugin directory must conform to the Terraform standard structure, example:
# /opt/terraform-plugins/registry.terraform.io/hashicorp/aws/5.30.0/linux_amd64/terraform-provider-aws_5.30.0_linux_amd64
# (After generating the mirror via terraform providers mirror, copy the registry.terraform.io directory to the plugin directory)
# 4. Difference from filesystem_mirror:
# - filesystem_mirror: Configured in .terraformrc, takes effect globally, suitable for long-term offline use
# - -plugin-dir: Temporary command-line parameter, takes effect for a single init, suitable for temporary testing and rapid deployment scenarios
# 5. Note: When using -plugin-dir, ensure that .terraformrc disables public network downloads (this configuration meets the requirement) to avoid conflicts